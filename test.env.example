# E2E Test Environment Configuration
# Copy to test.env and fill in actual values
# Usage: go run cmd/app/main.go -test

CONFIG_PATH=internal/pkg/config/config.yaml

# PostgreSQL (via SSH tunnel)
POSTGRES_USERNAME=e2e_test
POSTGRES_PASSWORD=<password>
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=encounterium_test

# MongoDB (via SSH tunnel)
MONGO_INITDB_ROOT_USERNAME=e2e_test
MONGO_INITDB_ROOT_PASSWORD=<password>
MONGO_HOST=localhost
MONGO_PORT=27018
MONGO_DB=encounterium_test

# Redis (via SSH tunnel, DB 2 for isolation from prod DB 0)
REDIS_PASSWORD=<prod_redis_password>
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=2

# MinIO (via SSH tunnel)
MINIO_HOST=localhost
MINIO_ROOT_USER=<user>
MINIO_ROOT_PASSWORD=<password>
MINIO_API_PORT=9002
S3_ACCESS_KEY=<key>
S3_SECRET_KEY=<secret>

# OAuth (fake values, not used in e2e)
REDIRECT_URI=http://localhost:5173/auth/callback/vk
CLIENT_ID=fake_vk_client
SECRET_KEY=fake_vk_secret
SERVICE_KEY=fake_vk_service
GOOGLE_CLIENT_ID=fake_google_id
GOOGLE_CLIENT_SECRET=fake_google_secret
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback/google
YANDEX_CLIENT_ID=fake_yandex_id
YANDEX_CLIENT_SECRET=fake_yandex_secret

# Gemini (disabled for e2e)
GEMINI_HOST=localhost
GEMINI_PORT=50052
EXTERNAL_VM_1_API_KEY=fake_key

# SOCKS5 proxy (disabled for e2e)
SOCKS5_PROXIE_IP=
SOCKS5_PROXIE_PORT=
